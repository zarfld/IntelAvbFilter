            "id" : "cpp/upcast-array-pointer-arithmetic",
            "kind" : "path-problem",
            "name" : "Upcast array used in pointer arithmetic",
            "precision" : "high",
            "problem.severity" : "warning",
            "security-severity" : "9.3"
          }
        }, {
